# =============================================================================
# VoiceNotes — Fichier de configuration
# =============================================================================
# INSTRUCTIONS :
#   1. Copiez ce fichier et renommez la copie en ".env"  (sans le mot "example")
#   2. Remplacez les valeurs entre < > par vos vraies valeurs
#   3. Ne partagez JAMAIS votre fichier .env (il contient des secrets)
# =============================================================================

# --- OBLIGATOIRE : Clé API Anthropic (pour la classification des thèmes) ---
# Obtenez votre clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=<votre-cle-api-anthropic-ici>

# --- OPTIONNEL : Dossier de stockage des données ---
# Par défaut : sous-dossier "data" à la racine du projet
# Exemple Windows : DATA_DIR=C:\Users\VotreNom\Documents\VoiceNotes\data
# DATA_DIR=

# --- OPTIONNEL : Modèle Whisper à utiliser ---
# Valeurs possibles : tiny, base, small, medium, large
# "base" = bon compromis vitesse/qualité (recommandé)
# "small" = meilleure précision, ~2x plus lent
# "large" = meilleure précision, nécessite beaucoup de RAM
WHISPER_MODEL=base

# --- OPTIONNEL : Langue principale des notes ---
# "fr" = français (par défaut)
# "en" = anglais
# Forcer la langue accélère légèrement la transcription
WHISPER_LANGUAGE=fr
